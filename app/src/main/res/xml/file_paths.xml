<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- FIXED: Allows access to the system root for SD card and Internal storage browsing -->
    <root-path
        name="root"
        path="." />

    <!-- FIXED: Added cache-path. Without this, the app CRASHES when previewing files (Glitch 4) -->
    <cache-path
        name="preview_cache"
        path="." />

    <!-- FIXED: Maps the internal files directory for the Offline Cache feature -->
    <files-path
        name="internal_files"
        path="." />

    <!-- Allows access to the standard external storage paths for compatibility -->
    <external-path
        name="external_files"
        path="." />

    <!-- Specific mapping for your app's external data folder -->
    <external-files-path
        name="app_external_files"
        path="." />
</paths>