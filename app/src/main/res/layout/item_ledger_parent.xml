<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Parent Row: Preset Folder Name -->
    <TextView
        android:id="@+id/tv_ledger_folder_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:text="Preset Folder Name" />

    <!-- Child Layout: Detailed View (Initially hidden/gone) -->
    <LinearLayout
        android:id="@+id/layout_ledger_child"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingLeft="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_ledger_seq_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:text="Files X to Y" />

        <TextView
            android:id="@+id/tv_ledger_file_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:text="Total files: 0" />

        <TextView
            android:id="@+id/tv_ledger_total_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:text="Size: 0 MB" />

    </LinearLayout>

</LinearLayout>