<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#DDDDDD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Account Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textSize="18sp"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_account_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_display_name"
                android:text="john.doe@gmail.com"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary" />

            <!-- FIXED: Moved status to the top right for better visibility -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#F0F0F0"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="ACTIVE"
                android:textAllCaps="true"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:ignore="SmallSp" />
        </RelativeLayout>

        <!-- ADDED: Storage Indicator (Crucial for Drive Cycling logic) -->
        <TextView
            android:id="@+id/tv_storage_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Storage Usage"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/pb_account_storage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:trackThickness="6dp"
            app:trackCornerRadius="3dp"
            app:indicatorColor="?attr/colorPrimary"
            android:progress="65" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_remove_account"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REMOVE"
                android:textColor="@color/cloudnest_status_red"
                app:icon="@android:drawable/ic_menu_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_switch_account"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="SET ACTIVE"
                android:textColor="?attr/colorPrimary"
                app:icon="@android:drawable/ic_menu_revert" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>